# 本地开发噪音
node_modules
.git
.ace-tool
.cursor
.vscode
.idea

# 构建产物（避免本地构建缓存污染 Docker 构建）
**/dist
**/*.tsbuildinfo

# 构建缓存与 lockfile
*.lockb

# 测试、文档与示例
**/test/**
**/tests/**
**/__tests__/**
**/*.test.ts
**/*.test.tsx
**/docs/
**/README.md
**/LICENSE

# 环境变量文件
.env
.env.local
.env.*.local

# GitHub Actions 与 CI 配置（构建镜像时不需要）
.github

# Docker 相关文件（避免递归构建上下文）
Dockerfile*
docker-compose*.yml
.dockerignore

# 系统文件
.DS_Store
Thumbs.db
